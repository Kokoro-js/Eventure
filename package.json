{
	"name": "eventure",
	"version": "0.4.2",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"require": "./dist/index.cjs",
			"import": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"event",
		"hook",
		"emit"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Kokoro-js/eventure.git"
	},
	"license": "Apache-2.0",
	"scripts": {
		"dev": "bun run --hot .src\\index.ts",
		"test": "bun test --conditions=\"source\"",
		"build": "tsdown",
		"bench:onlyEmit": "cd tinybench && bun ./onlyEmit.ts",
		"prepublish": "tsdown",
		"lint": "biome lint",
		"format:check": "biome format",
		"format": "biome format --write",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/bun": "^1.3.6",
		"tsdown": "0.20.0-beta.3",
		"type-fest": "^5.4.1",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"exports": {
			".": {
				"require": "./dist/index.cjs",
				"import": "./dist/index.mjs"
			},
			"./package.json": "./package.json"
		}
	}
}